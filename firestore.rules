rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // MASTER BYPASS FOR ADMIN
    // ===============================================================
    match /{document=**} {
      allow read, write: if request.auth != null && (
        request.auth.token.email == "mamad.ismanto@gmail.com" ||
        request.auth.token.email.toLower() == "mamad.ismanto@gmail.com" ||
        request.auth.token.get('email', '').matches('(?i)^mamad\\.ismanto@gmail\\.com$')
      );
    }
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, role, phoneNumber, bio, language, photoURL, createdAt
    //
    // Collection: appointments
    // Fields: patientId, patientName, doctorId, doctorName, date, time, status, queueNumber, reason, createdAt
    //
    // Collection: nutrition
    // Fields: patientId, date, foodName, calories, protein, carbs, fats, notes, createdAt
    //
    // Collection: clinicalNotes
    // Fields: patientId, doctorId, date, audioUrl, transcription, soapNotes, clinicalChecklist, createdAt
    //
    // Collection: consultations/{consultationId}/messages
    // Fields: consultationId, senderId, senderName, receiverId, text, type, createdAt
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "mamad.ismanto@gmail.com" ||
        request.auth.token.email.toLower() == "mamad.ismanto@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().get('role', 'patient') == 'admin')
      );
    }

    function isDoctor() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().get('role', 'patient') == 'doctor';
    }

    function isNurse() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().get('role', 'patient') == 'nurse';
    }

    function isStaff() {
      return isAuthenticated() && (
        request.auth.token.email == "mamad.ismanto@gmail.com" || 
        request.auth.token.email.toLower() == "mamad.ismanto@gmail.com" ||
        request.auth.token.get('email', '').matches('(?i)^mamad\\.ismanto@gmail\\.com$') || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData().get('role', 'patient') in ['admin', 'doctor', 'nurse'])
      );
    }

    // Validation Helpers
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'doctor', 'nurse', 'patient'];
    }

    function isValidAppointment(data) {
      return data.keys().hasAll(['patientId', 'date', 'time', 'status', 'type']) &&
             data.status in ['pending', 'accepted', 'declined', 'completed'] &&
             data.type in ['consultation', 'lab'];
    }

    function isValidNutrition(data) {
      return data.keys().hasAll(['patientId', 'date', 'foodName']) &&
             data.patientId is string &&
             data.foodName is string;
    }

    function isValidClinicalNote(data) {
      return data.keys().hasAll(['patientId', 'doctorId', 'date']) &&
             data.patientId is string &&
             data.doctorId is string;
    }

    function isValidPregnancySession(data) {
      return data.keys().hasAll(['patientId', 'lmp', 'edd', 'status']) &&
             data.status in ['active', 'completed'];
    }

    function isValidPregnancyRecord(data) {
      return data.keys().hasAll(['sessionId', 'patientId', 'doctorId', 'date']) &&
             data.patientId is string &&
             data.doctorId is string;
    }

    function isValidPreviousPregnancy(data) {
      return data.keys().hasAll(['patientId', 'year', 'outcome']) &&
             data.patientId is string &&
             data.outcome in ['healthy', 'abortion', 'stillbirth', 'miscarriage', 'other'];
    }

    function isValidPreviousPregnancyRecord(data) {
      return data.keys().hasAll(['previousPregnancyId', 'patientId', 'type', 'description', 'date']) &&
             data.patientId is string &&
             data.type in ['immunization', 'medicine', 'other'];
    }

    function isValidConsultationMessage(data) {
      return data.keys().hasAll(['consultationId', 'senderId', 'receiverId', 'text', 'type', 'createdAt']) &&
             data.consultationId is string &&
             data.senderId is string &&
             data.receiverId is string &&
             data.text is string &&
             data.type in ['text', 'audio'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow get: if isAuthenticated() && (
        isOwner(userId) || 
        isStaff() || 
        (resource != null && (resource.data.role == 'doctor' || resource.data.primaryDoctorId == request.auth.uid))
      );
      allow list: if isAuthenticated() && (
        isStaff() ||
        (resource != null && (resource.data.role == 'doctor' || resource.data.primaryDoctorId == request.auth.uid))
      );
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) || isAdmin() || isStaff()) &&
                    (request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow get: if isAuthenticated() && (
        isOwner(resource.data.patientId) || 
        isStaff()
      );
      allow list: if isAuthenticated() && (
        isStaff() ||
        resource.data.patientId == request.auth.uid
      );
      allow create: if isAuthenticated() && isValidAppointment(request.resource.data) && 
                    (isOwner(request.resource.data.patientId) || isStaff());
      allow update: if isAuthenticated() && isValidAppointment(request.resource.data) && 
                    (isOwner(resource.data.patientId) || isStaff());
      allow delete: if isAdmin();
    }

    match /nutrition/{intakeId} {
      allow get: if isAuthenticated() && (
        isOwner(resource.data.patientId) || 
        isStaff()
      );
      allow list: if isAuthenticated() && (
        isStaff() ||
        resource.data.patientId == request.auth.uid
      );
      allow create: if isAuthenticated() && isValidNutrition(request.resource.data) && 
                    isOwner(request.resource.data.patientId);
      allow update: if isAuthenticated() && isValidNutrition(request.resource.data) && 
                    isOwner(resource.data.patientId);
      allow delete: if isAuthenticated() && isOwner(resource.data.patientId);
    }

    match /clinicalNotes/{noteId} {
      allow get: if isAuthenticated() && (
        isOwner(resource.data.patientId) || 
        isStaff()
      );
      allow list: if isAuthenticated() && (
        isStaff() ||
        resource.data.patientId == request.auth.uid
      );
      allow create: if isAuthenticated() && isValidClinicalNote(request.resource.data) && 
                    (isDoctor() || isAdmin());
      allow update: if isAuthenticated() && isValidClinicalNote(request.resource.data) && 
                    (isDoctor() || isAdmin());
      allow delete: if isAdmin();
    }

    match /pregnancySessions/{sessionId} {
      allow get: if isAuthenticated() && (
        isOwner(resource.data.patientId) || 
        isStaff()
      );
      allow list: if isAuthenticated() && (
        isStaff() ||
        resource.data.patientId == request.auth.uid
      );
      allow create: if isAuthenticated() && isValidPregnancySession(request.resource.data) && 
                    (isOwner(request.resource.data.patientId) || isStaff());
      allow update: if isAuthenticated() && isValidPregnancySession(request.resource.data) && 
                    (isOwner(resource.data.patientId) || isStaff());
      allow delete: if isAdmin();
    }

    match /pregnancyRecords/{recordId} {
      allow get: if isAuthenticated() && (
        isOwner(resource.data.patientId) || 
        isStaff()
      );
      allow list: if isAuthenticated() && (
        isStaff() ||
        resource.data.patientId == request.auth.uid
      );
      allow create: if isAuthenticated() && isValidPregnancyRecord(request.resource.data) && 
                    isStaff();
      allow update: if isAuthenticated() && isValidPregnancyRecord(request.resource.data) && 
                    isStaff();
      allow delete: if isAdmin();
    }

    match /previousPregnancies/{pregnancyId} {
      allow get: if isAuthenticated() && (
        isOwner(resource.data.patientId) || 
        isStaff()
      );
      allow list: if isAuthenticated() && (
        isStaff() ||
        resource.data.patientId == request.auth.uid
      );
      allow create: if isAuthenticated() && isValidPreviousPregnancy(request.resource.data) && 
                    (isOwner(request.resource.data.patientId) || isStaff());
      allow update: if isAuthenticated() && isValidPreviousPregnancy(request.resource.data) && 
                    (isOwner(resource.data.patientId) || isStaff());
      allow delete: if isAdmin();
    }

    match /previousPregnancyRecords/{recordId} {
      allow get: if isAuthenticated() && (
        isOwner(resource.data.patientId) || 
        isStaff()
      );
      allow list: if isAuthenticated() && (
        isStaff() ||
        resource.data.patientId == request.auth.uid
      );
      allow create: if isAuthenticated() && isValidPreviousPregnancyRecord(request.resource.data) && 
                    (isOwner(request.resource.data.patientId) || isStaff());
      allow update: if isAuthenticated() && isValidPreviousPregnancyRecord(request.resource.data) && 
                    (isOwner(resource.data.patientId) || isStaff());
      allow delete: if isAdmin();
    }

    match /consultations/{consultationId}/messages/{messageId} {
      allow get: if isAuthenticated() && (consultationId.matches('.*' + request.auth.uid + '.*') || isStaff());
      allow list: if isAuthenticated() && (consultationId.matches('.*' + request.auth.uid + '.*') || isStaff());
      allow create: if isAuthenticated() && isValidConsultationMessage(request.resource.data) && 
                    (isOwner(request.resource.data.senderId) || isStaff());
    }
  }
}
